# Council + FV Configuration
# Copy to .env and fill in your values

# -- LLM (Ollama or OpenAI-compatible) --
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_MODEL=qwen3:14b
LLM_API_KEY=none

# -- FV Bridge --
BRIDGE_PORT=8000

# -- FAISS + SQLite memory paths --
AGENT_DB=runtime/agent.db
FAISS_PATH=runtime/facts.faiss

# -- CTT RAG index (optional) --
CTT_INDEX_DIR=

# -- Moltbook (optional) --
MOLTBOOK_API_KEY=
POSTING_ENABLED=0
MOLTBOOK_MODE=both
MOLTBOOK_SUBMOLT=general
MAX_ACTIONS_PER_RUN=10
COMMENT_INTERVAL_SECONDS=25
MAX_THREAD_DEPTH=10

# -- Gemini API (optional) --
GEMINI_API_KEY=

# -- Embedding device --
EMBED_DEVICE=cpu
